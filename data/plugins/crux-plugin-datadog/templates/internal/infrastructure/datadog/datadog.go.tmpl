// Package datadog provides Datadog APM tracer initialisation for {{ .service.name }}.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-datadog@1.0.0.
package datadog

import (
	"log/slog"
	"os"

	ddtracer "gopkg.in/DataDog/dd-trace-go.v1/ddtrace/tracer"
)

// Config holds Datadog APM settings.
type Config struct {
	ServiceName string
	Env         string
	Version     string
	AgentAddr   string
}

// Start initialises the Datadog APM tracer.
// Call this once at service startup before any HTTP handlers are registered.
// Call Stop() on graceful shutdown.
func Start(cfg Config, log *slog.Logger) {
	if os.Getenv("DD_TRACE_ENABLED") == "false" {
		log.Info("datadog apm disabled via DD_TRACE_ENABLED=false")
		return
	}

	ddtracer.Start(
		ddtracer.WithServiceName(cfg.ServiceName),
		ddtracer.WithEnv(cfg.Env),
		ddtracer.WithServiceVersion(cfg.Version),
		ddtracer.WithAgentAddr(cfg.AgentAddr),
		ddtracer.WithLogStartup(false),
	)

	log.Info("datadog apm started",
		slog.String("service", cfg.ServiceName),
		slog.String("env", cfg.Env),
	)
}

// Stop flushes and stops the Datadog tracer.
// Call this in the graceful shutdown hook.
func Stop() {
	ddtracer.Stop()
}

// DefaultConfig returns a Config populated from standard DD_* environment variables.
func DefaultConfig(serviceName, version string) Config {
	agentAddr := os.Getenv("DD_AGENT_HOST")
	if agentAddr == "" {
		agentAddr = "localhost:8126"
	}
	env := os.Getenv("DD_ENV")
	if env == "" {
		env = "{{ .dd_service_env }}"
	}
	return Config{
		ServiceName: serviceName,
		Env:         env,
		Version:     version,
		AgentAddr:   agentAddr,
	}
}
