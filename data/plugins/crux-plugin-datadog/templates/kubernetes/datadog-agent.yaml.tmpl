# Datadog Agent DaemonSet configuration for {{ .service.name }}
# Generated by crux {{ .meta.cli_version }} — crux-plugin-datadog@1.0.0
# Apply once per cluster namespace — not per service.
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .service.name }}-datadog-config
  labels:
    app: {{ .service.name }}
    team: {{ .service.team | default "platform" }}
data:
  DD_SERVICE: "{{ .service.name }}"
  DD_ENV: "{{ .dd_service_env }}"
  DD_TRACE_ENABLED: "{{ .dd_apm_enabled }}"
  DD_LOGS_INJECTION: "{{ .dd_log_injection }}"
  DD_RUNTIME_METRICS_ENABLED: "true"
