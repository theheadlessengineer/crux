# Generated by crux {{ .meta.cli_version }} — crux-plugin-spiffe@1.0.0.
# SPIFFE ID: spiffe://{{ .spiffe_trust_domain }}/{{ .service.name }}

default allow = false

# TODO: Replace with the actual SPIFFE IDs of services allowed to call {{ .service.name }}.
# Example: allow if input.source_spiffe_id == "spiffe://{{ .spiffe_trust_domain }}/order-service"

allow if {
    input.source_spiffe_id == "spiffe://{{ .spiffe_trust_domain }}/api-gateway"
}
