// Package identity manages SPIFFE workload identity via the SPIRE agent.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-spiffe@1.0.0.
package identity

import (
	"context"
	"fmt"
	"log/slog"

	"github.com/spiffe/go-spiffe/v2/spiffeid"
	"github.com/spiffe/go-spiffe/v2/workloadapi"
)

// Config holds SPIFFE workload identity settings.
type Config struct {
	// SocketPath is the SPIRE agent Unix socket path.
	// Default: /run/spire/sockets/agent.sock
	SocketPath string
	// TrustDomain is the SPIFFE trust domain (e.g. company.com).
	TrustDomain string
	// ServiceName is the service identifier within the trust domain.
	ServiceName string
}

// Client wraps the SPIFFE workload API client.
type Client struct {
	wl  *workloadapi.Client
	cfg Config
	log *slog.Logger
}

// New connects to the SPIRE agent and returns a Client.
// Fails fast if the agent socket is unreachable.
func New(ctx context.Context, cfg Config, log *slog.Logger) (*Client, error) {
	wl, err := workloadapi.New(ctx, workloadapi.WithAddr("unix://"+cfg.SocketPath))
	if err != nil {
		return nil, fmt.Errorf("spiffe: connect to agent: %w", err)
	}

	td, err := spiffeid.TrustDomainFromString(cfg.TrustDomain)
	if err != nil {
		_ = wl.Close()
		return nil, fmt.Errorf("spiffe: invalid trust domain %q: %w", cfg.TrustDomain, err)
	}

	log.Info("spiffe workload client connected",
		slog.String("trust_domain", td.String()),
		slog.String("service", cfg.ServiceName),
	)

	return &Client{wl: wl, cfg: cfg, log: log}, nil
}

// SVID returns the current X.509 SVID for this workload.
// The SVID is automatically rotated by the SPIRE agent.
func (c *Client) SVID(ctx context.Context) (*workloadapi.X509Context, error) {
	x509Ctx, err := c.wl.FetchX509Context(ctx)
	if err != nil {
		return nil, fmt.Errorf("spiffe: fetch x509 context: %w", err)
	}
	return x509Ctx, nil
}

// Close closes the workload API connection.
func (c *Client) Close() error {
	c.log.Info("spiffe closing workload client")
	return c.wl.Close()
}

// SpiffeID returns the SPIFFE ID for this service.
func (c *Client) SpiffeID() string {
	return fmt.Sprintf("spiffe://%s/%s", c.cfg.TrustDomain, c.cfg.ServiceName)
}
