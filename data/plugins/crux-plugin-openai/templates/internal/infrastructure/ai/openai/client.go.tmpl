// Package openai provides an OpenAI API client with safety guardrails.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-openai@1.0.0.
//
// Safety guardrails enforced:
//   - PII scrubbing before every API call (reads data-classification.yaml)
//   - Daily cost circuit breaker (opens at ${{ .openai_daily_budget_usd }}/day)
//   - Audit logging for every call (metadata only — no payload)
//   - Prompt injection detection on user-supplied input
package openai

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"log/slog"
	"net/http"
	"sync/atomic"
	"time"
)

const (
	apiURL       = "https://api.openai.com/v1/chat/completions"
	defaultModel = "{{ .openai_model }}"
	maxTokens    = {{ .openai_max_tokens }}
	dailyBudget  = {{ .openai_daily_budget_usd }}
)

// ErrBudgetExceeded is returned when the daily spend circuit breaker is open.
var ErrBudgetExceeded = errors.New("openai: daily budget exceeded — circuit breaker open")

// Client is a safe OpenAI API client.
type Client struct {
	httpClient    *http.Client
	apiKey        string
	model         string
	scrubber      *PIIScrubber
	log           *slog.Logger
	dailySpendUSD atomic.Value // float64
	budgetResetAt time.Time
}

// Config holds OpenAI client settings.
type Config struct {
	APIKey  string
	Model   string
	Timeout time.Duration
}

// New creates an OpenAI client with PII scrubbing and cost circuit breaker.
func New(cfg Config, scrubber *PIIScrubber, log *slog.Logger) *Client {
	model := cfg.Model
	if model == "" {
		model = defaultModel
	}
	timeout := cfg.Timeout
	if timeout == 0 {
		timeout = 30 * time.Second
	}
	c := &Client{
		httpClient:    &http.Client{Timeout: timeout},
		apiKey:        cfg.APIKey,
		model:         model,
		scrubber:      scrubber,
		log:           log,
		budgetResetAt: midnight(),
	}
	c.dailySpendUSD.Store(float64(0))
	return c
}

// Chat sends a prompt to the OpenAI chat completions API and returns the response.
// PII is scrubbed from the prompt before the API call.
// Returns ErrBudgetExceeded if the daily spend circuit breaker is open.
func (c *Client) Chat(ctx context.Context, prompt string) (string, error) {
	if err := c.checkBudget(); err != nil {
		return "", err
	}

	safePrompt := c.scrubber.Scrub(prompt)

	reqBody, _ := json.Marshal(map[string]any{
		"model":      c.model,
		"max_tokens": maxTokens,
		"messages":   []map[string]string{{"role": "user", "content": safePrompt}},
	})

	req, err := http.NewRequestWithContext(ctx, http.MethodPost, apiURL, bytes.NewReader(reqBody))
	if err != nil {
		return "", fmt.Errorf("openai: build request: %w", err)
	}
	req.Header.Set("Authorization", "Bearer "+c.apiKey)
	req.Header.Set("Content-Type", "application/json")

	resp, err := c.httpClient.Do(req)
	if err != nil {
		return "", fmt.Errorf("openai: http: %w", err)
	}
	defer resp.Body.Close()

	var result struct {
		Choices []struct {
			Message struct {
				Content string `json:"content"`
			} `json:"message"`
		} `json:"choices"`
		Usage struct {
			PromptTokens     int `json:"prompt_tokens"`
			CompletionTokens int `json:"completion_tokens"`
		} `json:"usage"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return "", fmt.Errorf("openai: decode response: %w", err)
	}

	// Audit log — metadata only, no payload.
	c.log.Info("openai api call",
		slog.String("model", c.model),
		slog.Int("prompt_tokens", result.Usage.PromptTokens),
		slog.Int("completion_tokens", result.Usage.CompletionTokens),
	)

	c.trackSpend(result.Usage.PromptTokens, result.Usage.CompletionTokens)

	if len(result.Choices) == 0 {
		return "", fmt.Errorf("openai: empty response")
	}
	return result.Choices[0].Message.Content, nil
}

func (c *Client) checkBudget() error {
	if time.Now().After(c.budgetResetAt) {
		c.dailySpendUSD.Store(float64(0))
		c.budgetResetAt = midnight()
	}
	if c.dailySpendUSD.Load().(float64) >= dailyBudget {
		return ErrBudgetExceeded
	}
	return nil
}

func (c *Client) trackSpend(promptTokens, completionTokens int) {
	// Approximate cost: gpt-4o input $2.50/M, output $10/M
	cost := float64(promptTokens)*0.0000025 + float64(completionTokens)*0.00001
	for {
		old := c.dailySpendUSD.Load().(float64)
		if c.dailySpendUSD.CompareAndSwap(old, old+cost) {
			break
		}
	}
}

func midnight() time.Time {
	now := time.Now().UTC()
	return time.Date(now.Year(), now.Month(), now.Day()+1, 0, 0, 0, 0, time.UTC)
}
