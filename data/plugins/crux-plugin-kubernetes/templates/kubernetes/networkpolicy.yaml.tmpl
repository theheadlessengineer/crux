# Default-deny ingress + egress. Declare your dependencies explicitly.
# Generated by crux {{ .meta.cli_version }} — crux-plugin-kubernetes@1.0.0.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ .service.name }}-ingress
spec:
  podSelector:
    matchLabels:
      app: {{ .service.name }}
  policyTypes: [Ingress]
  ingress:
    - from:
        - podSelector: {}  # Allow from same namespace — restrict further as needed
      ports:
        - port: 8080
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ .service.name }}-egress
spec:
  podSelector:
    matchLabels:
      app: {{ .service.name }}
  policyTypes: [Egress]
  egress:
    - ports:
        - port: 53   # DNS — always required
    # TODO: Declare your service's external dependencies:
    # - to:
    #     - ipBlock:
    #         cidr: "10.0.0.0/8"  # Internal cluster
