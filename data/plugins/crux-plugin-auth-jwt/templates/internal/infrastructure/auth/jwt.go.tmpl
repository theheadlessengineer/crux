// Claims represents the standard JWT claims expected by {{ .service.name }}.
// Extend with service-specific claims as needed.
type Claims struct {
	jwt.RegisteredClaims
	Roles []string `json:"roles,omitempty"`
}

// Config holds JWT validation settings.
type Config struct {
	// JWKSEndpoint is the JWKS URL for public key retrieval.
	// Set via JWKS_ENDPOINT environment variable.
	JWKSEndpoint string
	// Issuer is the expected token issuer (iss claim).
	Issuer string
	// Audience is the expected token audience (aud claim).
	Audience string
}

// Middleware returns a Gin middleware that validates Bearer JWT tokens.
// Unauthenticated requests receive 401. Invalid tokens receive 401.
// The parsed Claims are stored in the Gin context under the key "claims".
func Middleware(cfg Config, log *slog.Logger) gin.HandlerFunc {
	// TODO: Replace with JWKS key fetcher using cfg.JWKSEndpoint.
	// This stub uses a symmetric key for local development only.
	// See: https://pkg.go.dev/github.com/golang-jwt/jwt/v5
	return func(c *gin.Context) {
		raw := c.GetHeader("Authorization")
		if raw == "" || !strings.HasPrefix(raw, "Bearer ") {
			c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{"error": "missing bearer token"})
			return
		}
		tokenStr := strings.TrimPrefix(raw, "Bearer ")

		var claims Claims
		_, err := jwt.ParseWithClaims(tokenStr, &claims, func(t *jwt.Token) (any, error) {
			// TODO: fetch signing key from JWKS endpoint.
			return nil, errors.New("JWKS key resolver not configured — set JWKS_ENDPOINT")
		})
		if err != nil {
			log.Warn("jwt validation failed", slog.String("error", err.Error()))
			c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{"error": "invalid token"})
			return
		}

		c.Set("claims", &claims)
		c.Next()
	}
}

// RequireRole returns a Gin middleware that enforces RBAC role membership.
// Place after Middleware in the handler chain.
//
// TODO: Replace with your RBAC/ABAC policy engine (e.g. OPA, Casbin).
func RequireRole(role string) gin.HandlerFunc {
	return func(c *gin.Context) {
		claims, ok := c.MustGet("claims").(*Claims)
		if !ok {
			c.AbortWithStatusJSON(http.StatusForbidden, gin.H{"error": "no claims in context"})
			return
		}
		for _, r := range claims.Roles {
			if r == role {
				c.Next()
				return
			}
		}
		c.AbortWithStatusJSON(http.StatusForbidden, gin.H{"error": "insufficient role"})
	}
}
