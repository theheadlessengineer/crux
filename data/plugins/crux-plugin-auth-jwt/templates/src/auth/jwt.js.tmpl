'use strict';

const jwt = require('jsonwebtoken');

const JWKS_URL = process.env.JWKS_URL || '';

/**
 * Express middleware — verifies the Bearer JWT in the Authorization header.
 * Attaches decoded claims to req.user on success.
 */
function verifyToken(req, res, next) {
  const header = req.headers['authorization'] || '';
  if (!header.startsWith('Bearer ')) {
    return res.status(401).json({ title: 'Unauthorized', detail: 'Missing token' });
  }
  const token = header.slice(7);
  try {
    // TODO: configure public key / JWKS resolver from JWKS_URL
    req.user = jwt.decode(token);
    next();
  } catch {
    res.status(401).json({ title: 'Unauthorized', detail: 'Invalid token' });
  }
}

module.exports = { verifyToken };
