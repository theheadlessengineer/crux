// Package redis provides a Redis client with health check and graceful shutdown.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-redis@1.0.0.
package redis

import (
	"context"
	"fmt"
	"log/slog"
	"time"

	"github.com/redis/go-redis/v9"
)

// Config holds Redis connection settings.
type Config struct {
	Addr         string
	Password     string
	DB           int
	DialTimeout  time.Duration
	ReadTimeout  time.Duration
	WriteTimeout time.Duration
}

// Client wraps redis.Client with structured logging and health-check support.
type Client struct {
	rdb *redis.Client
	log *slog.Logger
}

// New creates a Redis client, pings the server, and returns a Client.
// Returns an error immediately if Redis is unreachable (fail-fast).
func New(ctx context.Context, cfg Config, log *slog.Logger) (*Client, error) {
	rdb := redis.NewClient(&redis.Options{
		Addr:         cfg.Addr,
		Password:     cfg.Password,
		DB:           cfg.DB,
		DialTimeout:  cfg.DialTimeout,
		ReadTimeout:  cfg.ReadTimeout,
		WriteTimeout: cfg.WriteTimeout,
	})

	if err := rdb.Ping(ctx).Err(); err != nil {
		_ = rdb.Close()
		return nil, fmt.Errorf("redis: ping: %w", err)
	}

	log.Info("redis connected", slog.String("addr", cfg.Addr))
	return &Client{rdb: rdb, log: log}, nil
}

// Client returns the underlying *redis.Client.
func (c *Client) Client() *redis.Client { return c.rdb }

// Ping checks the Redis connection — used by the health registry.
func (c *Client) Ping(ctx context.Context) error {
	if err := c.rdb.Ping(ctx).Err(); err != nil {
		return fmt.Errorf("redis: ping: %w", err)
	}
	return nil
}

// Close closes the Redis connection cleanly on SIGTERM.
func (c *Client) Close() error {
	c.log.Info("redis closing connection")
	return c.rdb.Close()
}
