terraform {
  required_version = ">= 1.6"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
  backend "s3" {
    bucket = "{{ .aws_remote_state_bucket }}"
    key    = "{{ .service.name }}/terraform.tfstate"
    region = "{{ .aws_region }}"
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      service      = "{{ .service.name }}"
      team         = "{{ .service.team }}"
      environment  = var.environment
      cost-centre  = "engineering"
      managed-by   = "terraform"
    }
  }
}
