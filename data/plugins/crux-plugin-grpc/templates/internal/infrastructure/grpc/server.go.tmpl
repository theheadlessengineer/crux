package grpc

import (
	"context"
	"fmt"
	"log/slog"
	"net"

	"google.golang.org/grpc"
	"google.golang.org/grpc/health"
	"google.golang.org/grpc/health/grpc_health_v1"
	{{ if .grpc_reflection -}}
	"google.golang.org/grpc/reflection"
	{{ end -}}
)

// Server wraps grpc.Server with structured logging.
type Server struct {
	srv    *grpc.Server
	health *health.Server
	port   string
	log    *slog.Logger
}

// New creates a gRPC server with health check and optional reflection.
func New(log *slog.Logger, opts ...grpc.ServerOption) *Server {
	srv := grpc.NewServer(opts...)
	hs := health.NewServer()
	grpc_health_v1.RegisterHealthServer(srv, hs)

	{{ if .grpc_reflection -}}
	reflection.Register(srv)
	{{ end -}}

	return &Server{srv: srv, health: hs, port: ":{{ .grpc_port }}", log: log}
}

// Server returns the underlying *grpc.Server for registering service implementations.
func (s *Server) Server() *grpc.Server { return s.srv }

// SetServingStatus updates the health check status for a service.
func (s *Server) SetServingStatus(service string, status grpc_health_v1.HealthCheckResponse_ServingStatus) {
	s.health.SetServingStatus(service, status)
}

// ListenAndServe starts the gRPC server on the configured port.
// Blocks until the server is stopped.
func (s *Server) ListenAndServe() error {
	lis, err := net.Listen("tcp", s.port)
	if err != nil {
		return fmt.Errorf("grpc: listen on %s: %w", s.port, err)
	}
	s.log.Info("grpc server listening", slog.String("port", s.port))
	return s.srv.Serve(lis)
}

// Shutdown gracefully stops the gRPC server.
func (s *Server) Shutdown(_ context.Context) error {
	s.log.Info("grpc server stopping")
	s.srv.GracefulStop()
	return nil
}
