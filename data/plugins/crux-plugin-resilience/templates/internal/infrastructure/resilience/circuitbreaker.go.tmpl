// Package resilience provides circuit breaker, bulkhead, and retry patterns.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-resilience@1.0.0.
package resilience

import (
	"context"
	"errors"
	"fmt"
	"log/slog"
	"sync"
	"time"
)

// ErrCircuitOpen is returned when the circuit breaker is open.
var ErrCircuitOpen = errors.New("circuit breaker open")

// State represents the circuit breaker state.
type State int

const (
	StateClosed   State = iota // normal operation
	StateOpen                  // failing fast
	StateHalfOpen              // probing recovery
)

// Config holds resilience settings — mirrors resilience.yaml.
type Config struct {
	// CircuitBreaker
	CBFailureThreshold int           // % failures before opening
	CBSuccessThreshold int           // successes before closing from half-open
	CBTimeout          time.Duration // how long to stay open before half-open

	// Retry
	RetryMaxAttempts int
	RetryBackoffBase time.Duration

	// Timeouts
	TimeoutHTTP time.Duration
	TimeoutDB   time.Duration
}

// DefaultConfig returns sensible defaults matching resilience.yaml.
func DefaultConfig() Config {
	return Config{
		CBFailureThreshold: {{ .resilience_cb_threshold }},
		CBSuccessThreshold: 3,
		CBTimeout:          60 * time.Second,
		RetryMaxAttempts:   3,
		RetryBackoffBase:   100 * time.Millisecond,
		TimeoutHTTP:        {{ .resilience_timeout_http_ms }} * time.Millisecond,
		TimeoutDB:          3000 * time.Millisecond,
	}
}

// CircuitBreaker is a simple two-state circuit breaker.
type CircuitBreaker struct {
	mu         sync.Mutex
	state      State
	failures   int
	successes  int
	openedAt   time.Time
	cfg        Config
	log        *slog.Logger
}

// NewCircuitBreaker creates a CircuitBreaker with the given config.
func NewCircuitBreaker(cfg Config, log *slog.Logger) *CircuitBreaker {
	return &CircuitBreaker{cfg: cfg, log: log}
}

// Execute runs fn through the circuit breaker.
// Returns ErrCircuitOpen immediately when the breaker is open.
func (cb *CircuitBreaker) Execute(ctx context.Context, fn func(context.Context) error) error {
	if err := cb.allow(); err != nil {
		return err
	}
	err := fn(ctx)
	cb.record(err)
	return err
}

func (cb *CircuitBreaker) allow() error {
	cb.mu.Lock()
	defer cb.mu.Unlock()
	switch cb.state {
	case StateOpen:
		if time.Since(cb.openedAt) > cb.cfg.CBTimeout {
			cb.state = StateHalfOpen
			cb.successes = 0
			cb.log.Info("circuit breaker half-open")
			return nil
		}
		return fmt.Errorf("%w: %s", ErrCircuitOpen, "retry after "+cb.cfg.CBTimeout.String())
	default:
		return nil
	}
}

func (cb *CircuitBreaker) record(err error) {
	cb.mu.Lock()
	defer cb.mu.Unlock()
	if err != nil {
		cb.failures++
		if cb.state == StateHalfOpen || cb.failures*100 >= cb.cfg.CBFailureThreshold*100 {
			cb.state = StateOpen
			cb.openedAt = time.Now()
			cb.failures = 0
			cb.log.Warn("circuit breaker opened")
		}
	} else {
		cb.failures = 0
		if cb.state == StateHalfOpen {
			cb.successes++
			if cb.successes >= cb.cfg.CBSuccessThreshold {
				cb.state = StateClosed
				cb.log.Info("circuit breaker closed")
			}
		}
	}
}
