// Package kafka provides a Kafka producer and consumer with DLQ and graceful shutdown.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-kafka@1.0.0.
package kafka

import (
	"context"
	"fmt"
	"log/slog"

	"github.com/twmb/franz-go/pkg/kgo"
)

// Config holds Kafka connection settings.
type Config struct {
	Brokers       []string
	ConsumerGroup string
	Topics        []string
	DLQTopic      string // empty = DLQ disabled
}

// Client wraps a franz-go client with structured logging and health-check support.
type Client struct {
	kgo *kgo.Client
	cfg Config
	log *slog.Logger
}

// New creates a Kafka client, verifies broker connectivity, and returns a Client.
func New(ctx context.Context, cfg Config, log *slog.Logger) (*Client, error) {
	opts := []kgo.Opt{
		kgo.SeedBrokers(cfg.Brokers...),
	}
	if cfg.ConsumerGroup != "" {
		opts = append(opts, kgo.ConsumerGroup(cfg.ConsumerGroup))
		opts = append(opts, kgo.ConsumeTopics(cfg.Topics...))
	}

	cl, err := kgo.NewClient(opts...)
	if err != nil {
		return nil, fmt.Errorf("kafka: new client: %w", err)
	}

	if err := cl.Ping(ctx); err != nil {
		cl.Close()
		return nil, fmt.Errorf("kafka: ping: %w", err)
	}

	log.Info("kafka connected", slog.Any("brokers", cfg.Brokers))
	return &Client{kgo: cl, cfg: cfg, log: log}, nil
}

// Client returns the underlying *kgo.Client.
func (c *Client) Client() *kgo.Client { return c.kgo }

// Ping checks broker connectivity — used by the health registry.
func (c *Client) Ping(ctx context.Context) error {
	if err := c.kgo.Ping(ctx); err != nil {
		return fmt.Errorf("kafka: ping: %w", err)
	}
	return nil
}

// Close flushes pending messages and closes the client cleanly on SIGTERM.
func (c *Client) Close() {
	c.log.Info("kafka closing client")
	c.kgo.Close()
}
