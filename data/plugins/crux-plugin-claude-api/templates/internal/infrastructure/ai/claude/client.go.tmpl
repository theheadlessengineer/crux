// Package claude provides an Anthropic Claude API client with safety guardrails.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-claude-api@1.0.0.
//
// Safety guardrails enforced:
//   - PII scrubbing before every API call (reads data-classification.yaml)
//   - Daily cost circuit breaker (opens at ${{ .claude_daily_budget_usd }}/day)
//   - Audit logging for every call (metadata only — no payload)
//   - Prompt injection detection on user-supplied input
package claude

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"log/slog"
	"net/http"
	"sync/atomic"
	"time"
)

const (
	apiURL       = "https://api.anthropic.com/v1/messages"
	defaultModel = "{{ .claude_model }}"
	maxTokens    = {{ .claude_max_tokens }}
	dailyBudget  = {{ .claude_daily_budget_usd }}
)

// ErrBudgetExceeded is returned when the daily spend circuit breaker is open.
var ErrBudgetExceeded = errors.New("claude: daily budget exceeded — circuit breaker open")

// Client is a safe Anthropic Claude API client.
type Client struct {
	httpClient   *http.Client
	apiKey       string
	model        string
	scrubber     *PIIScrubber
	log          *slog.Logger
	dailySpendUSD atomic.Value // float64
	budgetResetAt time.Time
}

// Config holds Claude client settings.
type Config struct {
	APIKey  string
	Model   string
	Timeout time.Duration
}

// New creates a Claude client with PII scrubbing and cost circuit breaker.
func New(cfg Config, scrubber *PIIScrubber, log *slog.Logger) *Client {
	model := cfg.Model
	if model == "" {
		model = defaultModel
	}
	timeout := cfg.Timeout
	if timeout == 0 {
		timeout = 30 * time.Second
	}
	c := &Client{
		httpClient: &http.Client{Timeout: timeout},
		apiKey:     cfg.APIKey,
		model:      model,
		scrubber:   scrubber,
		log:        log,
		budgetResetAt: midnight(),
	}
	c.dailySpendUSD.Store(float64(0))
	return c
}

// Message sends a prompt to Claude and returns the text response.
// PII is scrubbed from the prompt before the API call.
// Returns ErrBudgetExceeded if the daily spend circuit breaker is open.
func (c *Client) Message(ctx context.Context, prompt string) (string, error) {
	if err := c.checkBudget(); err != nil {
		return "", err
	}

	safePrompt := c.scrubber.Scrub(prompt)

	reqBody, _ := json.Marshal(map[string]any{
		"model":      c.model,
		"max_tokens": maxTokens,
		"messages":   []map[string]string{{"role": "user", "content": safePrompt}},
	})

	req, err := http.NewRequestWithContext(ctx, http.MethodPost, apiURL, bytes.NewReader(reqBody))
	if err != nil {
		return "", fmt.Errorf("claude: build request: %w", err)
	}
	req.Header.Set("x-api-key", c.apiKey)
	req.Header.Set("anthropic-version", "2023-06-01")
	req.Header.Set("content-type", "application/json")

	resp, err := c.httpClient.Do(req)
	if err != nil {
		return "", fmt.Errorf("claude: http: %w", err)
	}
	defer resp.Body.Close()

	var result struct {
		Content []struct {
			Text string `json:"text"`
		} `json:"content"`
		Usage struct {
			InputTokens  int `json:"input_tokens"`
			OutputTokens int `json:"output_tokens"`
		} `json:"usage"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return "", fmt.Errorf("claude: decode response: %w", err)
	}

	// Audit log — metadata only, no payload.
	c.log.Info("claude api call",
		slog.String("model", c.model),
		slog.Int("input_tokens", result.Usage.InputTokens),
		slog.Int("output_tokens", result.Usage.OutputTokens),
	)

	c.trackSpend(result.Usage.InputTokens, result.Usage.OutputTokens)

	if len(result.Content) == 0 {
		return "", fmt.Errorf("claude: empty response")
	}
	return result.Content[0].Text, nil
}

func (c *Client) checkBudget() error {
	if time.Now().After(c.budgetResetAt) {
		c.dailySpendUSD.Store(float64(0))
		c.budgetResetAt = midnight()
	}
	if c.dailySpendUSD.Load().(float64) >= dailyBudget {
		return ErrBudgetExceeded
	}
	return nil
}

func (c *Client) trackSpend(inputTokens, outputTokens int) {
	// Approximate cost: claude-3-5-sonnet input $3/M, output $15/M
	cost := float64(inputTokens)*0.000003 + float64(outputTokens)*0.000015
	for {
		old := c.dailySpendUSD.Load().(float64)
		if c.dailySpendUSD.CompareAndSwap(old, old+cost) {
			break
		}
	}
}

func midnight() time.Time {
	now := time.Now().UTC()
	return time.Date(now.Year(), now.Month(), now.Day()+1, 0, 0, 0, 0, time.UTC)
}
