# Generated by crux {{ .meta.cli_version }} — crux-plugin-terraform-gcp@1.0.0
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region
}

# Cloud SQL (PostgreSQL) instance
module "cloud_sql" {
  source     = "git::https://github.com/company/platform-terraform//modules/cloud-sql?ref=v1.0.0"
  project_id = var.project_id
  region     = var.region
  service    = var.service_name
  env        = var.environment
}

# Memorystore (Redis) instance
module "memorystore" {
  source     = "git::https://github.com/company/platform-terraform//modules/memorystore?ref=v1.0.0"
  project_id = var.project_id
  region     = var.region
  service    = var.service_name
  env        = var.environment
}
