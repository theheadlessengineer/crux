// Package postgres provides a PostgreSQL connection pool with health check and graceful shutdown.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-postgresql@1.0.0.
package postgres

import (
	"context"
	"database/sql"
	"fmt"
	"log/slog"
	"time"

	_ "github.com/lib/pq" // PostgreSQL driver
)

// Config holds PostgreSQL connection settings read from environment variables.
type Config struct {
	DSN             string
	MaxOpenConns    int
	MaxIdleConns    int
	ConnMaxLifetime time.Duration
}

// DB wraps sql.DB with structured logging and health-check support.
type DB struct {
	db  *sql.DB
	log *slog.Logger
}

// New opens a PostgreSQL connection pool, pings the server, and returns a DB.
// Returns an error immediately if the database is unreachable (fail-fast).
func New(ctx context.Context, cfg Config, log *slog.Logger) (*DB, error) {
	db, err := sql.Open("postgres", cfg.DSN)
	if err != nil {
		return nil, fmt.Errorf("postgres: open: %w", err)
	}

	db.SetMaxOpenConns(cfg.MaxOpenConns)
	db.SetMaxIdleConns(cfg.MaxIdleConns)
	db.SetConnMaxLifetime(cfg.ConnMaxLifetime)

	if err := db.PingContext(ctx); err != nil {
		_ = db.Close()
		return nil, fmt.Errorf("postgres: ping: %w", err)
	}

	log.Info("postgres connected",
		slog.String("dsn_host", dsnHost(cfg.DSN)),
		slog.Int("max_open_conns", cfg.MaxOpenConns),
	)

	return &DB{db: db, log: log}, nil
}

// DB returns the underlying *sql.DB for use in repositories.
func (d *DB) DB() *sql.DB { return d.db }

// Ping checks the database connection — used by the health registry.
func (d *DB) Ping(ctx context.Context) error {
	if err := d.db.PingContext(ctx); err != nil {
		return fmt.Errorf("postgres: ping: %w", err)
	}
	return nil
}

// Close closes the connection pool cleanly on SIGTERM.
func (d *DB) Close() error {
	d.log.Info("postgres closing connection pool")
	return d.db.Close()
}

// dsnHost extracts the host portion from a DSN for safe logging (no credentials).
func dsnHost(dsn string) string {
	// Minimal extraction — avoids importing a URL parser.
	for _, part := range splitDSN(dsn) {
		if len(part) > 5 && part[:5] == "host=" {
			return part[5:]
		}
	}
	return "unknown"
}

func splitDSN(dsn string) []string {
	var parts []string
	start := 0
	for i, c := range dsn {
		if c == ' ' {
			parts = append(parts, dsn[start:i])
			start = i + 1
		}
	}
	parts = append(parts, dsn[start:])
	return parts
}
