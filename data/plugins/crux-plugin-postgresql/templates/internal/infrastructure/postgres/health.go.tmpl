	"{{ .service.module }}/internal/domain/health"
)

// RegisterHealth registers the PostgreSQL ping as a readiness dependency.
// The service will report unhealthy until the database is reachable.
func (d *DB) RegisterHealth(registry *health.Registry) {
	registry.Register("postgres", func(ctx context.Context) error {
		return d.Ping(ctx)
	})
}
