# Generated by crux {{ .meta.cli_version }} — crux-plugin-gitlab-ci@1.0.0
# GitLab CI/CD pipeline for {{ .service.name }}

stages:
  - lint
  - test
  - build
  - scan
  - deploy

variables:
  IMAGE: "{{ .gitlab_container_registry }}:$CI_COMMIT_SHORT_SHA"
  COVERAGE_THRESHOLD: "{{ .gitlab_coverage_threshold }}"

lint:
  stage: lint
  image: golangci/golangci-lint:latest
  script:
    - golangci-lint run ./...

test:
  stage: test
  image: golang:1.22
  script:
    - go test -race -coverprofile=coverage.out ./...
    - go tool cover -func=coverage.out
  coverage: '/total:\s+\(statements\)\s+(\d+\.\d+)%/'
  artifacts:
    reports:
      coverage_report:
        coverage_format: cobertura
        path: coverage.xml

sast:
  stage: scan
  include:
    - template: Security/SAST.gitlab-ci.yml

container_scan:
  stage: scan
  image: docker:latest
  services:
    - docker:dind
  script:
    - docker build -t $IMAGE .
    - docker run --rm -v /var/run/docker.sock:/var/run/docker.sock
        aquasec/trivy image --exit-code 1 --severity HIGH,CRITICAL $IMAGE

build:
  stage: build
  image: docker:latest
  services:
    - docker:dind
  script:
    - docker build -t $IMAGE .
    - docker push $IMAGE
  only:
    - main

{{ if ne .gitlab_deploy_env "none" -}}
deploy_{{ .gitlab_deploy_env }}:
  stage: deploy
  image: bitnami/kubectl:latest
  script:
    - kubectl set image deployment/{{ .service.name }} {{ .service.name }}=$IMAGE -n {{ .gitlab_deploy_env }}
  environment:
    name: {{ .gitlab_deploy_env }}
  {{ if eq .gitlab_deploy_env "prod" -}}
  when: manual
  {{ else -}}
  only:
    - main
  {{ end -}}
{{ end -}}
