// Package mysql provides a MySQL connection pool with health check and graceful shutdown.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-mysql@1.0.0.
package mysql

import (
	"context"
	"database/sql"
	"fmt"
	"log/slog"
	"time"

	_ "github.com/go-sql-driver/mysql" // MySQL driver
)

// Config holds MySQL connection settings.
type Config struct {
	DSN             string
	MaxOpenConns    int
	MaxIdleConns    int
	ConnMaxLifetime time.Duration
}

// DB wraps sql.DB with structured logging and health-check support.
type DB struct {
	db  *sql.DB
	log *slog.Logger
}

// New opens a MySQL connection pool, pings the server, and returns a DB.
func New(ctx context.Context, cfg Config, log *slog.Logger) (*DB, error) {
	db, err := sql.Open("mysql", cfg.DSN)
	if err != nil {
		return nil, fmt.Errorf("mysql: open: %w", err)
	}

	db.SetMaxOpenConns(cfg.MaxOpenConns)
	db.SetMaxIdleConns(cfg.MaxIdleConns)
	db.SetConnMaxLifetime(cfg.ConnMaxLifetime)

	if err := db.PingContext(ctx); err != nil {
		_ = db.Close()
		return nil, fmt.Errorf("mysql: ping: %w", err)
	}

	log.Info("mysql connected", slog.Int("max_open_conns", cfg.MaxOpenConns))
	return &DB{db: db, log: log}, nil
}

// DB returns the underlying *sql.DB.
func (d *DB) DB() *sql.DB { return d.db }

// Ping checks the database connection — used by the health registry.
func (d *DB) Ping(ctx context.Context) error {
	if err := d.db.PingContext(ctx); err != nil {
		return fmt.Errorf("mysql: ping: %w", err)
	}
	return nil
}

// Close closes the connection pool cleanly on SIGTERM.
func (d *DB) Close() error {
	d.log.Info("mysql closing connection pool")
	return d.db.Close()
}
