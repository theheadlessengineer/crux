// Package rabbitmq provides a RabbitMQ client with producer, consumer, and health check.
// Generated by crux {{ .meta.cli_version }} — crux-plugin-rabbitmq@1.0.0.
package rabbitmq

import (
	"context"
	"fmt"
	"log/slog"

	amqp "github.com/rabbitmq/amqp091-go"
)

// Config holds RabbitMQ connection settings.
type Config struct {
	URL          string
	ExchangeName string
	ExchangeType string // {{ .rmq_exchange_type }}
	QueueName    string
	DLQEnabled   bool   // {{ .rmq_dlq }}
}

// Client wraps an AMQP connection with structured logging.
type Client struct {
	conn    *amqp.Connection
	channel *amqp.Channel
	cfg     Config
	log     *slog.Logger
}

// New connects to RabbitMQ, declares the exchange, and returns a Client.
func New(ctx context.Context, cfg Config, log *slog.Logger) (*Client, error) {
	conn, err := amqp.Dial(cfg.URL)
	if err != nil {
		return nil, fmt.Errorf("rabbitmq: dial: %w", err)
	}

	ch, err := conn.Channel()
	if err != nil {
		_ = conn.Close()
		return nil, fmt.Errorf("rabbitmq: open channel: %w", err)
	}

	if err := ch.ExchangeDeclare(cfg.ExchangeName, cfg.ExchangeType, true, false, false, false, nil); err != nil {
		_ = conn.Close()
		return nil, fmt.Errorf("rabbitmq: declare exchange: %w", err)
	}

	{{ if .rmq_dlq -}}
	// Declare DLQ exchange and queue.
	dlqExchange := cfg.ExchangeName + ".dlq"
	if err := ch.ExchangeDeclare(dlqExchange, "direct", true, false, false, false, nil); err != nil {
		_ = conn.Close()
		return nil, fmt.Errorf("rabbitmq: declare dlq exchange: %w", err)
	}
	{{ end -}}

	log.Info("rabbitmq connected",
		slog.String("exchange", cfg.ExchangeName),
		slog.String("type", cfg.ExchangeType),
	)
	return &Client{conn: conn, channel: ch, cfg: cfg, log: log}, nil
}

// Publish sends a message to the configured exchange with the given routing key.
func (c *Client) Publish(ctx context.Context, routingKey string, body []byte) error {
	return c.channel.PublishWithContext(ctx, c.cfg.ExchangeName, routingKey, false, false,
		amqp.Publishing{ContentType: "application/json", Body: body})
}

// Ping checks the AMQP connection — used by the health registry.
func (c *Client) Ping(_ context.Context) error {
	if c.conn.IsClosed() {
		return fmt.Errorf("rabbitmq: connection closed")
	}
	return nil
}

// Close closes the channel and connection cleanly on SIGTERM.
func (c *Client) Close() error {
	c.log.Info("rabbitmq closing connection")
	_ = c.channel.Close()
	return c.conn.Close()
}
