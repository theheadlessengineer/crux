{
  "title": "{{ .service.name }} — Four Golden Signals",
  "uid": "{{ .service.name }}-golden-signals",
  "tags": ["{{ .service.name }}", "{{ .service.team }}", "generated"],
  "panels": [
    {
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "targets": [{"expr": "rate(http_requests_total{job=\"{{ .service.name }}\"}[5m])"}]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "targets": [{"expr": "rate(http_requests_total{job=\"{{ .service.name }}\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"{{ .service.name }}\"}[5m]) * 100"}]
    },
    {
      "title": "p50 / p95 / p99 Latency (ms)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"{{ .service.name }}\"}[5m])) * 1000", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"{{ .service.name }}\"}[5m])) * 1000", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"{{ .service.name }}\"}[5m])) * 1000", "legendFormat": "p99"}
      ]
    },
    {
      "title": "Saturation — CPU Utilisation (%)",
      "type": "timeseries",
      "targets": [{"expr": "rate(container_cpu_usage_seconds_total{pod=~\"{{ .service.name }}-.*\"}[5m]) * 100"}]
    }
  ]
}
