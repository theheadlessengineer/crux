groups:
  - name: {{ .service.name }}.rules
    rules:
      - alert: ServiceDown
        expr: up{job="{{ .service.name }}"} == 0
        for: 1m
        labels:
          severity: critical
          service: {{ .service.name }}
          team: {{ .service.team }}
        annotations:
          summary: "{{ .service.name }} is down"
          description: "No healthy instances of {{ .service.name }} have been detected for 1 minute."

      - alert: HighErrorRate
        expr: rate(http_requests_total{job="{{ .service.name }}",status=~"5.."}[5m]) / rate(http_requests_total{job="{{ .service.name }}"}[5m]) > {{ .prom_error_rate_threshold | default "0.05" }}
        for: 5m
        labels:
          severity: warning
          service: {{ .service.name }}
          team: {{ .service.team }}
        annotations:
          summary: "High error rate on {{ .service.name }}"
          description: "Error rate has exceeded {{ .prom_error_rate_threshold | default "5" }}% for 5 minutes."

      - alert: HighP99Latency
        expr: histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job="{{ .service.name }}"}[5m])) > {{ .prom_p99_latency_ms | default "500" | divf 1000 }}
        for: 5m
        labels:
          severity: warning
          service: {{ .service.name }}
          team: {{ .service.team }}
        annotations:
          summary: "High p99 latency on {{ .service.name }}"
          description: "p99 latency has exceeded {{ .prom_p99_latency_ms | default "500" }}ms for 5 minutes."

      - alert: HighMemoryUsage
        expr: container_memory_working_set_bytes{pod=~"{{ .service.name }}-.*"} / container_spec_memory_limit_bytes > 0.85
        for: 10m
        labels:
          severity: warning
          service: {{ .service.name }}
          team: {{ .service.team }}
        annotations:
          summary: "High memory usage on {{ .service.name }}"
          description: "Memory usage has exceeded 85% of the limit for 10 minutes."
