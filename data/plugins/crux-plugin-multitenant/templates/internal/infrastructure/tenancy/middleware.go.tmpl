package tenancy

import (
	"net/http"

	"github.com/gin-gonic/gin"
)

const tenantHeader = "{{ .mt_tenant_header }}"

// Middleware extracts the tenant ID from the {{ .mt_tenant_header }} header
// and injects it into the request context.
// Returns 400 if the header is missing or empty.
func Middleware() gin.HandlerFunc {
	return func(c *gin.Context) {
		tenantID := c.GetHeader(tenantHeader)
		if tenantID == "" {
			c.AbortWithStatusJSON(http.StatusBadRequest, gin.H{
				"error": "missing required header: " + tenantHeader,
			})
			return
		}
		ctx := WithTenant(c.Request.Context(), tenantID)
		c.Request = c.Request.WithContext(ctx)
		c.Set("tenant_id", tenantID)
		c.Next()
	}
}
