package tenancy

import (
	"context"
	"errors"
)

type contextKey struct{}

// ErrNoTenant is returned when no tenant ID is present in the context.
var ErrNoTenant = errors.New("tenancy: no tenant ID in context")

// FromContext extracts the tenant ID from ctx.
// Returns ErrNoTenant if not set.
func FromContext(ctx context.Context) (string, error) {
	v, ok := ctx.Value(contextKey{}).(string)
	if !ok || v == "" {
		return "", ErrNoTenant
	}
	return v, nil
}

// WithTenant returns a new context carrying the given tenant ID.
func WithTenant(ctx context.Context, tenantID string) context.Context {
	return context.WithValue(ctx, contextKey{}, tenantID)
}

// CacheKey returns a tenant-namespaced cache key.
// Format: tenant:<tenantID>:<key>
func CacheKey(tenantID, key string) string {
	return "tenant:" + tenantID + ":" + key
}
