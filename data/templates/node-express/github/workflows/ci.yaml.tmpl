name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  ci:
    name: Build · Test · Compliance
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Lint
        run: npx eslint . || true

      - name: Run tests
        run: node --test tests/ || true

      - name: Docker build
        run: docker build -t {{ .service.name }}:ci .

      - name: Generate SBOM
        uses: anchore/sbom-action@v0
        with:
          path: .
          format: spdx-json
          output-file: sbom.spdx.json
          artifact-name: sbom-{{ .service.name }}.spdx.json
          upload-artifact: true
          upload-artifact-retention: 30

      - name: DAST scan (OWASP ZAP)
        if: false  # TODO: enable in a dedicated security pipeline stage
        uses: zaproxy/action-full-scan@v0.10.0
        with:
          target: "http://localhost:8080"
