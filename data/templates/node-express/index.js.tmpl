'use strict';

const app = require('./src/app');
const { logger } = require('./src/logging');

const PORT = process.env.PORT || 8080;

const server = app.listen(PORT, () => {
  logger.info({ msg: `starting ${process.env.SERVICE_NAME || '{{ .service.name }}'}`, port: PORT, env: process.env.ENVIRONMENT || 'development' });
});

// Graceful shutdown — Tier 1 standard.
function shutdown(signal) {
  logger.info({ msg: `received ${signal} — initiating graceful shutdown` });
  server.close(() => {
    logger.info({ msg: 'HTTP server closed' });
    process.exit(0);
  });
  setTimeout(() => {
    logger.error({ msg: 'shutdown timeout — forcing exit' });
    process.exit(1);
  }, 30_000);
}

process.on('SIGTERM', () => shutdown('SIGTERM'));
process.on('SIGINT', () => shutdown('SIGINT'));
