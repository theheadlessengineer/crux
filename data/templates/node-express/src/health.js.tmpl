// Health endpoints for {{ .service.name }}.
// Generated by crux {{ .meta.cli_version }}.
// Tier 1 standard: /health /ready /live /metrics /version

'use strict';

const { Router } = require('express');

const router = Router();
const START_TIME = Date.now();
const SERVICE_NAME = process.env.SERVICE_NAME || '{{ .service.name }}';
const VERSION = process.env.VERSION || 'dev';
const COMMIT = process.env.COMMIT || 'unknown';
const BUILD_TIME = process.env.BUILD_TIME || 'unknown';

router.get('/health', (_req, res) => {
  res.json({ status: 'ok', service: SERVICE_NAME });
});

router.get('/ready', (_req, res) => {
  res.json({ status: 'ready' });
});

router.get('/live', (_req, res) => {
  res.json({ status: 'alive', uptime_seconds: Math.floor((Date.now() - START_TIME) / 1000) });
});

router.get('/metrics', (_req, res) => {
  // TODO: replace with prom-client metrics once wired.
  res.type('text/plain; version=0.0.4').send('# HELP up Service is up\n# TYPE up gauge\nup 1\n');
});

router.get('/version', (_req, res) => {
  res.json({ service: SERVICE_NAME, version: VERSION, commit: COMMIT, build_time: BUILD_TIME });
});

module.exports = router;
