// Structured JSON logging for {{ .service.name }}.
// Generated by crux {{ .meta.cli_version }}.
// Tier 1 standard: JSON with traceId, correlationId, service, env, level, timestamp.

'use strict';

const SERVICE_NAME = process.env.SERVICE_NAME || '{{ .service.name }}';
const ENVIRONMENT = process.env.ENVIRONMENT || 'development';
const LOG_LEVEL_ORDER = { debug: 0, info: 1, warn: 2, error: 3 };
const MIN_LEVEL = LOG_LEVEL_ORDER[process.env.LOG_LEVEL?.toLowerCase()] ?? 1;

function log(level, fields) {
  if ((LOG_LEVEL_ORDER[level] ?? 0) < MIN_LEVEL) return;
  const entry = {
    timestamp: new Date().toISOString(),
    level: level.toUpperCase(),
    service: SERVICE_NAME,
    environment: ENVIRONMENT,
    ...fields,
  };
  process.stdout.write(JSON.stringify(entry) + '\n');
}

const logger = {
  debug: (fields) => log('debug', fields),
  info: (fields) => log('info', fields),
  warn: (fields) => log('warn', fields),
  error: (fields) => log('error', fields),
};

module.exports = { logger };
