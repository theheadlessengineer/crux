# {{ .service.name }} — Makefile
# Generated by crux {{ .meta.cli_version }}. Do not remove standard targets.

.PHONY: help build run test lint clean dev

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

build: ## Compile the application
	mvn -q package -DskipTests

run: ## Run the service locally
	mvn spring-boot:run

test: ## Run all tests
	mvn test

lint: ## Run checkstyle
	mvn checkstyle:check 2>/dev/null || echo "checkstyle not configured — skipping"

clean: ## Remove build artifacts
	mvn clean

dev: lint test ## Full development workflow (lint → test)
