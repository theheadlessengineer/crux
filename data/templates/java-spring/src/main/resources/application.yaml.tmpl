# {{ .service.name }} — application configuration
# Generated by crux {{ .meta.cli_version }}.

spring:
  application:
    name: {{ .service.name }}

server:
  port: ${PORT:8080}
  shutdown: graceful

management:
  endpoints:
    web:
      exposure:
        include: prometheus
  endpoint:
    health:
      show-details: never
  metrics:
    export:
      prometheus:
        enabled: true

app:
  version: ${VERSION:dev}
  commit: ${COMMIT:unknown}
  build-time: ${BUILD_TIME:unknown}

logging:
  pattern:
    console: '{"timestamp":"%d{yyyy-MM-dd'\''T'\''HH:mm:ss.SSSZ}","level":"%p","service":"{{ .service.name }}","environment":"${ENVIRONMENT:development}","message":"%m"}%n'

spring.lifecycle.timeout-per-shutdown-phase: 30s
