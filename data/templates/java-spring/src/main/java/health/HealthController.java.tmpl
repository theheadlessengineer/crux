// Health endpoints for {{ .service.name }}.
// Generated by crux {{ .meta.cli_version }}.
// Tier 1 standard: /health /ready /live /metrics /version
package com.company.{{ camel .service.name }}.health;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import java.lang.management.ManagementFactory;
import java.util.Map;

@RestController
public class HealthController {

    @Value("${spring.application.name:{{ .service.name }}}")
    private String serviceName;

    @Value("${app.version:dev}")
    private String version;

    @Value("${app.commit:unknown}")
    private String commit;

    @Value("${app.build-time:unknown}")
    private String buildTime;

    @GetMapping("/health")
    public ResponseEntity<Map<String, String>> health() {
        return ResponseEntity.ok(Map.of("status", "ok", "service", serviceName));
    }

    @GetMapping("/ready")
    public ResponseEntity<Map<String, String>> ready() {
        return ResponseEntity.ok(Map.of("status", "ready"));
    }

    @GetMapping("/live")
    public ResponseEntity<Map<String, Object>> live() {
        long uptimeSeconds = ManagementFactory.getRuntimeMXBean().getUptime() / 1000;
        return ResponseEntity.ok(Map.of("status", "alive", "uptime_seconds", uptimeSeconds));
    }

    @GetMapping("/version")
    public ResponseEntity<Map<String, String>> versionInfo() {
        return ResponseEntity.ok(Map.of(
            "service", serviceName,
            "version", version,
            "commit", commit,
            "build_time", buildTime
        ));
    }
}
