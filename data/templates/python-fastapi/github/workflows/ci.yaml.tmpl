name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  ci:
    name: Build · Test · Compliance
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: Install dependencies
        run: pip install -r requirements.txt ruff pytest

      - name: Lint
        run: ruff check .

      - name: Format check
        run: ruff format --check .

      - name: Run tests
        run: pytest tests/ -v --tb=short

      - name: Docker build
        run: docker build -t {{ .service.name }}:ci .

      - name: Generate SBOM
        uses: anchore/sbom-action@v0
        with:
          path: .
          format: spdx-json
          output-file: sbom.spdx.json
          artifact-name: sbom-{{ .service.name }}.spdx.json
          upload-artifact: true
          upload-artifact-retention: 30

      - name: DAST scan (OWASP ZAP)
        if: false  # TODO: enable in a dedicated security pipeline stage
        uses: zaproxy/action-full-scan@v0.10.0
        with:
          target: "http://localhost:8080"
