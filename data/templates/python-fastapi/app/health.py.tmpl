# Health endpoints for {{ .service.name }}.
# Generated by crux {{ .meta.cli_version }}.
# Tier 1 standard: /health /ready /live /metrics /version

import time

from fastapi import APIRouter
from fastapi.responses import JSONResponse, PlainTextResponse

from app.config import Settings

router = APIRouter()
_start_time = time.time()
settings = Settings()


@router.get("/health", tags=["health"])
async def health() -> JSONResponse:
    """Aggregate health — returns 200 when all checks pass."""
    return JSONResponse({"status": "ok", "service": settings.service_name})


@router.get("/ready", tags=["health"])
async def ready() -> JSONResponse:
    """Readiness probe — returns 200 when the service can accept traffic."""
    return JSONResponse({"status": "ready"})


@router.get("/live", tags=["health"])
async def live() -> JSONResponse:
    """Liveness probe — returns 200 while the process is alive."""
    return JSONResponse({"status": "alive", "uptime_seconds": int(time.time() - _start_time)})


@router.get("/metrics", tags=["health"])
async def metrics() -> PlainTextResponse:
    """Prometheus metrics endpoint stub. Wire prometheus_client here."""
    # TODO: replace with prometheus_client.generate_latest() once metrics are wired.
    return PlainTextResponse(
        "# HELP up Service is up\n# TYPE up gauge\nup 1\n",
        media_type="text/plain; version=0.0.4",
    )


@router.get("/version", tags=["health"])
async def version() -> JSONResponse:
    """Returns build metadata."""
    return JSONResponse({
        "service": settings.service_name,
        "version": settings.version,
        "commit": settings.commit,
        "build_time": settings.build_time,
    })
