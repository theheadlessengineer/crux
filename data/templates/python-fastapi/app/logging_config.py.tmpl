# Structured JSON logging for {{ .service.name }}.
# Generated by crux {{ .meta.cli_version }}.

import json
import logging
import sys
import time
from typing import Any


class JSONFormatter(logging.Formatter):
    """Emits log records as structured JSON matching the org-wide log schema."""

    def __init__(self, service_name: str, environment: str) -> None:
        super().__init__()
        self._service = service_name
        self._environment = environment

    def format(self, record: logging.LogRecord) -> str:
        entry: dict[str, Any] = {
            "timestamp": self.formatTime(record, "%Y-%m-%dT%H:%M:%S.") + f"{int(record.msecs):03d}Z",
            "level": record.levelname,
            "service": self._service,
            "environment": self._environment,
            "message": record.getMessage(),
        }
        # Inject OTel trace context if present on the record.
        for field in ("traceId", "spanId", "correlationId"):
            if hasattr(record, field):
                entry[field] = getattr(record, field)
        if record.exc_info:
            entry["exception"] = self.formatException(record.exc_info)
        return json.dumps(entry)


def configure_logging(log_level: str, service_name: str, environment: str) -> None:
    handler = logging.StreamHandler(sys.stdout)
    handler.setFormatter(JSONFormatter(service_name, environment))
    root = logging.getLogger()
    root.handlers = [handler]
    root.setLevel(getattr(logging, log_level.upper(), logging.INFO))
