# alerts.yaml — generated by crux
# Four golden signal alert rules for {{ .service.name }}.
# Thresholds reference slo.yaml values — calibrate both files together.
# Validate with: promtool check rules alerts.yaml

groups:
  - name: {{ .service.name }}.golden-signals
    rules:

      # ── Error Rate ────────────────────────────────────────────────────────
      # Alert when the HTTP 5xx error rate exceeds 1% over 5 minutes.
      # Adjust the threshold to match your availability SLO (see slo.yaml).
      - alert: HighErrorRate
        expr: |
          (
            rate(http_requests_total{job="{{ .service.name }}", status=~"5.."}[5m])
            /
            rate(http_requests_total{job="{{ .service.name }}"}[5m])
          ) > 0.01
        for: 5m
        labels:
          severity: critical
          service: {{ .service.name }}
        annotations:
          summary: "High error rate on {{ .service.name }}"
          description: "HTTP 5xx rate is {{ "{{" }} $value | humanizePercentage {{ "}}" }} — exceeds 1% threshold."

      # ── Latency ───────────────────────────────────────────────────────────
      # Alert when p99 latency exceeds the SLO target (default: 500ms).
      # Update the threshold to match latency-p99.target_ms in slo.yaml.
      - alert: HighP99Latency
        expr: |
          histogram_quantile(0.99,
            rate(http_request_duration_seconds_bucket{job="{{ .service.name }}"}[5m])
          ) > 0.5
        for: 5m
        labels:
          severity: warning
          service: {{ .service.name }}
        annotations:
          summary: "High p99 latency on {{ .service.name }}"
          description: "p99 latency is {{ "{{" }} $value | humanizeDuration {{ "}}" }} — exceeds 500ms SLO target."

      # ── Traffic ───────────────────────────────────────────────────────────
      # Alert when request rate drops to zero (service may be down or unreachable).
      # Adjust the threshold based on your expected minimum traffic.
      - alert: NoTraffic
        expr: |
          rate(http_requests_total{job="{{ .service.name }}"}[5m]) == 0
        for: 5m
        labels:
          severity: warning
          service: {{ .service.name }}
        annotations:
          summary: "No traffic on {{ .service.name }}"
          description: "Request rate has been zero for 5 minutes — service may be unreachable."

      # ── Saturation ────────────────────────────────────────────────────────
      # Alert when container memory usage exceeds 80% of its limit.
      # Adjust the threshold and resource limits in your K8s deployment.
      - alert: HighMemorySaturation
        expr: |
          (
            container_memory_working_set_bytes{container="{{ .service.name }}"}
            /
            container_spec_memory_limit_bytes{container="{{ .service.name }}"}
          ) > 0.8
        for: 10m
        labels:
          severity: warning
          service: {{ .service.name }}
        annotations:
          summary: "High memory saturation on {{ .service.name }}"
          description: "Memory usage is {{ "{{" }} $value | humanizePercentage {{ "}}" }} of limit."
