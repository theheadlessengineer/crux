extends: ['@commitlint/config-conventional']

rules:
  # Allowed commit types — extend this list as needed.
  type-enum:
    - 2
    - always
    - [feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert]

  # Subject line must not end with a period.
  subject-full-stop:
    - 2
    - never
    - .

  # Subject line must start with a lowercase letter.
  subject-case:
    - 2
    - always
    - lower-case

  # Maximum subject line length.
  header-max-length:
    - 2
    - always
    - 100
