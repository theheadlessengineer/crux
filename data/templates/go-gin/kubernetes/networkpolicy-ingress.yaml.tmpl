apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ .service.name }}-deny-ingress
  namespace: {{ .service.namespace }}
spec:
  podSelector:
    matchLabels:
      app: {{ .service.name }}
  policyTypes:
    - Ingress
  ingress: []
