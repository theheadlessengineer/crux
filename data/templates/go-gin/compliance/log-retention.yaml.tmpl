# log-retention.yaml — generated by crux
# Declare log and data retention periods per environment.
# These values are applied to S3 lifecycle policies, RDS backup retention,
# and Kafka topic retention via Terraform modules.
#
# TODO (required before production):
#   - Confirm retention periods with your Legal / Compliance team.
#   - Ensure Terraform modules reference this file.

service: {{ .service.name }}

environments:
  production:
    # Application log retention in days (minimum 90 for SOC2).
    logs_days: 90
    # RDS automated backup retention in days (minimum 35 for SOC2).
    db_backups_days: 35
    # Kafka topic retention in milliseconds (604800000 = 7 days).
    kafka_retention_ms: 604800000

  staging:
    logs_days: 30
    db_backups_days: 7
    kafka_retention_ms: 86400000  # 1 day

  development:
    logs_days: 7
    db_backups_days: 1
    kafka_retention_ms: 3600000   # 1 hour
