// RouterConfig holds the dependencies required to build the router.
type RouterConfig struct {
	Logger    *slog.Logger
	Registry  *health.Registry
	BuildInfo BuildInfo
}

// NewRouter builds and returns the Gin engine with all Tier 1 middleware applied.
//
// Middleware order (outermost → innermost):
//  1. ErrorMiddleware  — panic recovery → RFC 7807 500
//  2. SecurityHeaders  — HSTS, CSP, X-Frame-Options, etc.
//  3. CORSMiddleware   — env-driven CORS policy
//  4. InputSanitization — path traversal, null bytes, body size, Content-Type
//  5. tracing.Middleware — W3C traceparent extract + server span
//  6. logging.Middleware — inject trace_id/span_id into log context
func NewRouter(cfg RouterConfig) *gin.Engine {
	r := gin.New()

	tracer := otel.Tracer("{{ .service.name }}")

	r.Use(
		errorMiddleware(),
		securityHeaders(),
		corsMiddleware(),
		inputSanitization(),
		tracing.Middleware(tracer),
		logging.Middleware(),
	)

	// Health endpoints — no auth, no rate limiting.
	healthHandler := NewHealthHandler(cfg.Registry, cfg.BuildInfo)
	healthHandler.RegisterRoutes(&gin.RouterGroup{})

	base := r.Group("")
	healthHandler.RegisterRoutes(base)

	// TODO: Register your API routes here.
	// Example:
	//   v1 := r.Group("/v1")
	//   v1.Use(authMiddleware)
	//   v1.GET("/example", exampleHandler)

	return r
}

// securityHeaders sets hardened default security response headers.
func securityHeaders() gin.HandlerFunc {
	return func(c *gin.Context) {
		h := c.Writer.Header()
		h.Set("Content-Security-Policy", "default-src 'self'")
		h.Set("X-Content-Type-Options", "nosniff")
		h.Set("X-Frame-Options", "DENY")
		h.Set("Strict-Transport-Security", "max-age=31536000; includeSubDomains")
		h.Set("Referrer-Policy", "strict-origin-when-cross-origin")
		h.Set("Permissions-Policy", "geolocation=(), microphone=(), camera=()")
		c.Next()
	}
}

// corsMiddleware applies CORS policy driven by environment variables.
func corsMiddleware() gin.HandlerFunc {
	origins := os.Getenv("CORS_ALLOWED_ORIGINS")
	methods := envOr("CORS_ALLOWED_METHODS", "GET,POST,PUT,DELETE")
	headers := envOr("CORS_ALLOWED_HEADERS", "Authorization,Content-Type")
	allowed := splitTrimmed(origins)

	return func(c *gin.Context) {
		origin := c.GetHeader("Origin")
		if origin != "" && isAllowed(origin, allowed) {
			c.Header("Access-Control-Allow-Origin", origin)
			c.Header("Access-Control-Allow-Methods", methods)
			c.Header("Access-Control-Allow-Headers", headers)
			c.Header("Vary", "Origin")
		}
		if c.Request.Method == "OPTIONS" {
			c.AbortWithStatus(204)
			return
		}
		c.Next()
	}
}

// inputSanitization enforces baseline input sanitization.
func inputSanitization() gin.HandlerFunc {
	return func(c *gin.Context) {
		path := c.Request.URL.Path
		if strings.Contains(path, "../") || strings.Contains(path, "..%2F") ||
			strings.Contains(path, "..%2f") {
			c.AbortWithStatus(400)
			return
		}
		for _, vals := range c.Request.URL.Query() {
			for _, v := range vals {
				if strings.ContainsRune(v, 0) {
					c.AbortWithStatus(400)
					return
				}
			}
		}
		c.Next()
	}
}

// errorMiddleware recovers from panics and returns a 500 Problem response.
func errorMiddleware() gin.HandlerFunc {
	return gin.CustomRecovery(func(c *gin.Context, _ any) {
		c.Header("Content-Type", "application/problem+json")
		c.JSON(500, gin.H{
			"type":   "/errors/internal",
			"title":  "Internal Server Error",
			"status": 500,
			"detail": "An unexpected error occurred.",
		})
	})
}

func envOr(key, fallback string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return fallback
}

func splitTrimmed(s string) []string {
	if s == "" {
		return nil
	}
	parts := strings.Split(s, ",")
	out := make([]string, 0, len(parts))
	for _, p := range parts {
		if t := strings.TrimSpace(p); t != "" {
			out = append(out, t)
		}
	}
	return out
}

func isAllowed(origin string, allowed []string) bool {
	for _, a := range allowed {
		if a == origin {
			return true
		}
	}
	return false
}
