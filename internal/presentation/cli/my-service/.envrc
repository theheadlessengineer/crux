# direnv — local secret injection from Vault dev namespace.
# Run `direnv allow` after cloning to activate.
# Never commit real secrets to this file.

export SERVICE_NAME="my-service"
export ENVIRONMENT="development"
export PORT="8080"
export LOG_LEVEL="debug"

# Uncomment and configure to fetch secrets from Vault:
# export VAULT_ADDR="https://vault.internal.company.com"
# eval "$(vault kv get -format=json secret/dev/my-service | \
#   jq -r '.data.data | to_entries[] | "export \(.key)=\(.value)"')"
